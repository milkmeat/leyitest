# LLM 密钥配置模板
# 复制为 llm_secret.yaml 并填入真实值:
#   cp config/llm_secret.yaml.example config/llm_secret.yaml

model: "glm-4.7"                                    # LLM 模型名称
base_url: "https://open.bigmodel.cn/api/paas/v4"    # OpenAI 兼容 API 地址
api_key: "your-api-key-here"                         # API 密钥

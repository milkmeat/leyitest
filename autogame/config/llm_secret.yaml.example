# LLM 密钥配置模板
# 复制为 llm_secret.yaml 并填入真实值:
#   cp config/llm_secret.yaml.example config/llm_secret.yaml

# ──────────────────────────────────────────────────────────────
# 新格式：多 Profile 配置（推荐）
# ──────────────────────────────────────────────────────────────
# 通过修改 active_profile 快速切换不同的 LLM 配置

active_profile: "ollama"  # 当前使用的 profile，可选值: ollama / zhipu / openai / deepseek

profiles:
  # 本地 Ollama 模型（适合快速测试，无需 API 费用）
  ollama:
    model: "llama3.2"                     # 或其他已下载的模型: qwen2.5, mistral, etc.
    base_url: "http://localhost:11434/v1"  # Ollama 默认地址
    api_key: "sk-ollama"                  # Ollama 可填任意值

  # 智谱 AI GLM 系列
  zhipu:
    model: "GLM-4.5-Air"                  # 或 GLM-4.7, GLM-4-Flash
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    api_key: "your-zhipu-api-key-here"

  # OpenAI 官方
  openai:
    model: "gpt-4o-mini"                  # 或 gpt-4o, gpt-3.5-turbo
    base_url: "https://api.openai.com/v1"
    api_key: "your-openai-api-key-here"

  # DeepSeek
  deepseek:
    model: "deepseek-chat"
    base_url: "https://api.deepseek.com/v1"
    api_key: "your-deepseek-api-key-here"

  # 其他兼容 OpenAI API 的服务
  custom:
    model: "your-model-name"
    base_url: "https://your-api-endpoint/v1"
    api_key: "your-api-key-here"


# ──────────────────────────────────────────────────────────────
# 旧格式：直接配置（向后兼容）
# ──────────────────────────────────────────────────────────────
# 如果不需要多配置切换，可以直接使用以下简化格式:
#
# model: "glm-4.7"
# base_url: "https://open.bigmodel.cn/api/paas/v4"
# api_key: "your-api-key-here"

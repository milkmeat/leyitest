{
  "name": "frozenisland",
  "display_name": "Frozen Island Pro",
  "package": "leyi.frozenislandpro",

  "default_resources": {
    "food": 0,
    "wood": 0,
    "stone": 0,
    "gold": 0
  },
  "resource_keywords": {
    "food": ["食物", "粮食", "food"],
    "wood": ["木材", "木头", "wood"],
    "stone": ["石头", "石材", "stone"],
    "gold": ["金币", "金", "gold"]
  },
  "resource_order": ["food", "wood", "stone", "gold"],

  "scenes": [
    "main_city", "world_map", "hero", "hero_recruit", "hero_upgrade",
    "battle", "popup", "exit_dialog", "loading", "story_dialogue",
    "shoot_mini_game", "building_upgrade", "battle_formation", "unknown"
  ],

  "known_tasks": [
    "collect_resources", "upgrade_building", "train_troops",
    "claim_rewards", "navigate_main_city", "navigate_world_map",
    "close_popup", "check_mail", "collect_daily"
  ],

  "known_popups": [],
  "reward_templates": [],
  "close_text_patterns": ["关闭", "close", "×", "X"],
  "claim_text_patterns": ["领取", "claim", "collect", "收集", "一键领取"],

  "action_button_templates": [],
  "action_button_texts": [
    "一键上阵", "出战", "开始战斗", "攻击",
    "建造", "升级", "训练", "研究", "确定", "前往",
    "开始", "使用", "派遣", "出征", "行军", "下一个", "领取"
  ],

  "popup_close_templates": ["close_x", "close_x.2"],
  "popup_close_texts": [
    "返回领地", "关闭", "确定", "确认", "取消", "返回", "领取", "前往", "全部领取"
  ],

  "finger_ncc_threshold": 0.68,

  "grid_cols": 8,
  "grid_rows": 6,

  "loop_start_sleep": 1.4,

  "auto_priorities": {
    "popup": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "button", "text_match": "领取|claim|collect|一键领取", "action": "tap"},
      {"type": "button", "text_match": "确[认定]|ok|confirm", "action": "tap"},
      {"type": "button", "text_match": "返回.*", "action": "tap"},
      {"type": "button", "text_match": "继续", "action": "tap"},
      {"type": "button", "text_match": "^前往$", "action": "tap"},
      {"type": "icon", "name": "close_x", "action": "tap"},
      {"type": "icon", "name": "close_x.2", "action": "tap"},
      {"type": "icon", "name": "close_x_flag", "action": "tap"},
      {"type": "button", "text_match": "关闭|close", "action": "tap"},
      {"action": "tap_blank"}
    ],
    "loading": [],
    "main_city": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "green_check", "action": "tap"},
      {"type": "red_dot", "action": "tap"}
    ],
    "world_map": [
      {"type": "finger", "action": "tap_fingertip"}
    ],
    "hero": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "icon", "name": "back_arrow", "action": "tap"},
      {"action": "tap_blank"}
    ],
    "hero_recruit": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "button", "text_match": "免费", "action": "tap"},
      {"type": "icon", "name": "back_arrow", "action": "tap"}
    ],
    "building_upgrade": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "button", "text_match": "升级|建造|下一个", "color_match": "blue", "action": "tap"},
      {"action": "tap_blank"}
    ],
    "hero_upgrade": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "button", "text_match": "升级", "color_match": "blue", "has_red_text": false, "action": "tap"},
      {"type": "icon", "name": "back_arrow", "action": "tap"}
    ],
    "battle_formation": [],
    "story_dialogue": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "text", "value_match": "跳过|skip", "action": "tap"},
      {"type": "icon", "name": "down_triangle", "action": "tap"},
      {"action": "tap_center"}
    ],
    "_default": [
      {"type": "finger", "action": "tap_fingertip"},
      {"type": "icon", "name": "back_arrow", "action": "tap"},
      {"type": "button", "text_match": "领取|claim|collect", "action": "tap"},
      {"action": "tap_blank"}
    ]
  }
}
